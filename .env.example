# =============================================================================
# Minerva – Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=minerva
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=minerva

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Set to false in production
DEBUG=false

# HTTP port Nginx listens on (host side)
HTTP_PORT=80

# ---------------------------------------------------------------------------
# JWT / Security
# ---------------------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS
# Set to the public URL(s) of your frontend (comma-separated JSON list).
# In production this should be your domain, e.g. ["https://minerva.example.com"]
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:80"]

# ---------------------------------------------------------------------------
# OIDC (optional – leave blank to disable)
# ---------------------------------------------------------------------------
OIDC_ENABLED=false
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# OIDC_REDIRECT_URI=https://minerva.example.com/api/v1/auth/oidc/callback
