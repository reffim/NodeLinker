# =============================================================================
# Minerva – Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=minerva
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=minerva

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Set to false in production
DEBUG=false

# HTTP port Nginx listens on (host side)
HTTP_PORT=80

# ---------------------------------------------------------------------------
# JWT / Security
# ---------------------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS
# Set to the public URL(s) of your frontend (comma-separated JSON list).
# In production this should be your domain, e.g. ["https://minerva.example.com"]
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:80"]

# ---------------------------------------------------------------------------
# OIDC (optional – leave blank to disable)
# Used for web UI access authentication (browser login).
# ---------------------------------------------------------------------------
OIDC_ENABLED=false
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# OIDC_REDIRECT_URI=https://minerva.example.com/api/v1/auth/oidc/callback

# ---------------------------------------------------------------------------
# HashiCorp Vault (used for Ansible SSH credential storage)
# Set VAULT_TOKEN to a token with read/write access to the KV v2 mount.
# ---------------------------------------------------------------------------
VAULT_URL=http://vault:8200
VAULT_TOKEN=change-me-vault-token
VAULT_MOUNT_PATH=secret

# ---------------------------------------------------------------------------
# Job Log Storage
# Real-time logs are streamed via Redis pub/sub.
# Completed logs are compressed and stored here after the job finishes.
#   LOG_STORAGE_TYPE=local   → stores to LOG_STORAGE_BASE_PATH on the host
#   LOG_STORAGE_TYPE=s3      → (future) stores to S3-compatible object storage
# ---------------------------------------------------------------------------
LOG_STORAGE_TYPE=local
LOG_STORAGE_BASE_PATH=/var/minerva/logs
