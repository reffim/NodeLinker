# =============================================================================
# NodeLinker Backend – Environment Variables
# Copy to .env and fill in values before running locally.
# For Docker Compose, use the root .env.example instead.
# =============================================================================

APP_NAME=NodeLinker
DEBUG=true

DATABASE_URL=postgresql+asyncpg://nodelinker:nodelinker@localhost:5432/nodelinker
REDIS_URL=redis://localhost:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# OIDC (optional – leave blank/false to disable)
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=oidc
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email profile
